---
import Base from '../layouts/Base.astro';
---
<Base lang="zh" title="404 | MOPM 2026">
  <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center">
    <p class="text-6xl font-extrabold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-bold">找不到這個頁面</h1>
    <p class="mt-2 text-muted">Sorry, this page could not be found.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-lg bg-accent px-5 py-2.5 font-semibold text-accent-contrast">回首頁 Home</a>
      <a href="/agenda" class="rounded-lg border border-line px-5 py-2.5 font-medium hover:border-accent">議程 Agenda</a>
    </div>
  </section>
</Base>
