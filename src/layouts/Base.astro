---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import yaml from 'js-yaml';
import fs from 'node:fs';
import type { Lang } from '../lib/i18n';

const { lang = 'zh', title = 'MOPM 2026', description } = Astro.props as {
  lang?: Lang;
  title?: string;
  description?: string;
};

const c: any = yaml.load(fs.readFileSync('src/data/conference.yaml', 'utf8'));
const p = (o: any, b: string) => o?.[`${b}_${lang}`] ?? o?.[`${b}_zh`] ?? '';
const desc = description ?? `${p(c, 'title')}｜${p(c, 'theme')}・${p(c, 'date')}・${p(c, 'venue')}`;

const site = Astro.site ?? new URL('https://2026.mopm.tw');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(c.banner, site).href;

// hreflang：zh 在無 /en 前綴的路徑、en 在 /en 前綴
const path = Astro.url.pathname;
const zhPath = path.replace(/^\/en(?=\/|$)/, '') || '/';
const enPath = path.startsWith('/en') ? path : '/en' + (path === '/' ? '/' : path);
---
<html lang={lang === 'zh' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-Hant" href={new URL(zhPath, site).href} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(zhPath, site).href} />
    <meta name="theme-color" content="#1d4ed8" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MOPM" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_TW' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- 頁面專屬 head（Event JSON-LD 等結構化資料） -->
    <slot name="head" />
  </head>
  <body class="bg-bg text-ink">
    <Nav lang={lang} />
    <main><slot /></main>
    <Footer lang={lang} />
  </body>
</html>
