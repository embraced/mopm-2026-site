---
import { t, type Lang } from '../lib/i18n';
const { lang } = Astro.props as { lang: Lang };
const formUrl = 'https://forms.gle/TODO';
const desc = lang === 'zh' ? '歡迎投稿壁報摘要，截止日期將公布。' : 'Poster abstract submission is open. Deadline TBA.';
const btn = lang === 'zh' ? '前往投稿表單' : 'Go to submission form';
---
<section id="abstract" class="mx-auto max-w-3xl px-4 py-16 text-center">
  <h2 class="mb-4 text-2xl font-bold text-accent">{t(lang, 'section.abstract')}</h2>
  <p class="mb-6 text-ink/80">{desc}</p>
  <a href={formUrl} target="_blank" rel="noopener" class="inline-block rounded-lg bg-accent px-6 py-3 font-semibold text-accent-contrast">{btn}</a>
</section>
