---
// Event 結構化資料（schema.org JSON-LD）。研討會被 AI 答案引擎引用的最高槓桿項。
// 完全資料驅動：主辦改 conference/societies/speakers 的 yaml，這裡自動更新。
import yaml from 'js-yaml';
import fs from 'node:fs';
import type { Lang } from '../lib/i18n';

const { lang } = Astro.props as { lang: Lang };
const c: any = yaml.load(fs.readFileSync('src/data/conference.yaml', 'utf8'));
const societies: any[] = (yaml.load(fs.readFileSync('src/data/societies.yaml', 'utf8')) as any[]) ?? [];
const speakers: any[] = (yaml.load(fs.readFileSync('src/data/speakers.yaml', 'utf8')) as any[]) ?? [];

const site = (Astro.site ?? new URL('https://2026.mopm.tw')).href.replace(/\/$/, '');
const pageUrl = lang === 'en' ? `${site}/en/` : `${site}/`;
const p = (o: any, b: string) => o?.[`${b}_${lang}`] ?? o?.[`${b}_zh`] ?? '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: p(c, 'theme') ? `${p(c, 'title')} — ${p(c, 'theme')}` : p(c, 'title'),
  description: p(c, 'theme') || p(c, 'title'),
  startDate: c.start_date,
  endDate: c.end_date,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  inLanguage: lang === 'zh' ? 'zh-Hant' : 'en',
  url: pageUrl,
  image: [new URL(c.banner, site).href],
  location: {
    '@type': 'Place',
    name: p(c, 'venue'),
    address: {
      '@type': 'PostalAddress',
      streetAddress: lang === 'zh' ? '羅斯福路四段1號' : 'No. 1, Sec. 4, Roosevelt Rd, Da’an Dist.',
      addressLocality: lang === 'zh' ? '臺北市' : 'Taipei',
      postalCode: '10617',
      addressCountry: 'TW',
    },
  },
  organizer: societies.map((s) => ({ '@type': 'Organization', name: p(s, 'name') })),
  performer: speakers.map((s) => ({
    '@type': 'Person',
    name: s.name,
    ...(p(s, 'affiliation') ? { affiliation: { '@type': 'Organization', name: p(s, 'affiliation') } } : {}),
  })),
  offers: {
    '@type': 'Offer',
    url: pageUrl + (c.register_anchor || '#register'),
    availability: 'https://schema.org/InStock',
    category: 'Registration',
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
