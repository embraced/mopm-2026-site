---
import yaml from 'js-yaml';
import fs from 'node:fs';
import { t, pick, type Lang } from '../lib/i18n';
const { lang } = Astro.props as { lang: Lang };
const speakers: any[] = yaml.load(fs.readFileSync('src/data/speakers.yaml', 'utf8')) as any[];
---
<section id="speakers" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="mb-8 text-2xl font-bold text-accent">{t(lang, 'section.speakers')}</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {speakers.map((s) => (
      <article class="rounded-lg border border-line bg-surface p-5">
        <div class="mb-3 h-24 w-24 rounded-full bg-line">{s.photo && <img src={s.photo} alt={s.name} class="h-24 w-24 rounded-full object-cover" />}</div>
        <h3 class="font-bold">{s.name}</h3>
        <p class="text-sm text-muted">{pick(s, 'title', lang)}・{pick(s, 'affiliation', lang)}</p>
        <p class="mt-2 text-sm text-ink/80">{pick(s, 'bio', lang)}</p>
      </article>
    ))}
  </div>
</section>
