---
import yaml from 'js-yaml';
import fs from 'node:fs';
import { t, type Lang } from '../lib/i18n';
const { lang } = Astro.props as { lang: Lang };
const data: any = yaml.load(fs.readFileSync('src/data/sponsors.yaml', 'utf8'));
const tiers: any[] = (data.tiers ?? []).filter((tr: any) => (tr.sponsors ?? []).length > 0);
---
{tiers.length > 0 && (
  <section id="sponsors" class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="mb-8 text-2xl font-bold text-accent">{t(lang, 'section.sponsors')}</h2>
    {tiers.map((tier) => (
      <div class="mb-8">
        <h3 class="mb-4 text-center text-sm font-bold uppercase tracking-wider text-muted">{lang === 'zh' ? tier.name_zh : tier.name_en}</h3>
        <div class="flex flex-wrap items-center justify-center gap-6">
          {tier.sponsors.map((s: any) => (
            <a href={s.url} target="_blank" rel="noopener" class="rounded-lg border border-line bg-surface p-4">
              {s.logo ? <img src={s.logo} alt={s.name} class="h-16 object-contain" /> : <span class="text-sm">{s.name}</span>}
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
)}
