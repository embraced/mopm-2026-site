---
import { splitSpeaker, type Agenda } from '../lib/agenda';
import { pick, type Lang } from '../lib/i18n';
const { agenda, lang } = Astro.props as { agenda: Agenda; lang: Lang };
const chipAll = lang === 'zh' ? '全部' : 'All';
const venueClass: Record<string, string> = {
  '博雅館101': 'border-t101', '博雅館102': 'border-t102', '博雅館103': 'border-t103',
};
// 會場 → 對應 session 顏色變數（與時間軸卡片左框同色，達成「頂部 chip 連動顏色」）
const venueVar: Record<string, string> = {
  '博雅館101': '--color-track-101', '博雅館102': '--color-track-102', '博雅館103': '--color-track-103',
};
---
<div class="agenda-mobile">
  <div class="sticky top-14 z-10 -mx-4 mb-3 flex gap-2 overflow-x-auto bg-bg/95 px-4 py-2 backdrop-blur">
    <button class="venue-chip chip-all rounded-full px-3 py-1 text-xs font-medium" data-venue="all" data-active="true" style="--chip: var(--color-accent)">{chipAll}</button>
    {agenda.venues.map((v) => (
      <button
        class="venue-chip rounded-full px-3 py-1 text-xs font-medium"
        data-venue={v}
        data-active="false"
        style={`--chip: var(${venueVar[v] ?? '--color-accent'})`}
      >{v.replace('博雅館', '')}</button>
    ))}
  </div>

  {agenda.days.map((day) => (
    <section class="mb-8">
      <h3 class="mb-2 text-base font-bold text-accent">{lang === 'zh' ? day.label_zh : day.label_en}</h3>
      {day.slots.map((slot) => (
        slot.type === 'parallel' ? (
          <div class="slot-parallel mb-3">
            <div class="mb-1 text-xs font-bold text-accent">{slot.time}・{lang === 'zh' ? '平行場次' : 'Parallel'}</div>
            {slot.tracks!.map((tk) => (
              <div class={`track-card mb-2 rounded-md border-l-4 ${venueClass[tk.venue] ?? 'border-line'} bg-surface p-3`} data-venue={tk.venue}>
                <div class="text-xs font-bold text-muted">{tk.venue.replace('博雅館', '')}・{tk.session}</div>
                <div class="text-sm font-medium">{pick(tk, 'title', lang) || tk.title_zh}</div>
                {tk.speaker && (() => {
                  const sp = splitSpeaker(tk.speaker);
                  return (
                    <div class="text-xs text-muted">
                      {sp.person}{sp.affiliation && <span class="block opacity-80">{sp.affiliation}</span>}
                    </div>
                  );
                })()}
              </div>
            ))}
          </div>
        ) : (
          <div class="mb-3 rounded-md border-l-4 border-accent bg-surface p-3" data-venue="plenary">
            <div class="text-xs font-bold text-accent">{slot.time}{slot.venue ? '・' + slot.venue.replace('博雅館', '') : ''}</div>
            <div class="text-sm font-medium">{pick(slot, 'title', lang) || slot.title_zh}</div>
            {slot.speaker && (() => {
              const sp = splitSpeaker(slot.speaker);
              const aff = sp.affiliation || pick(slot, 'affiliation', lang);
              return (
                <div class="text-xs text-muted">
                  {sp.person}{aff && <span class="block opacity-80">{aff}</span>}
                </div>
              );
            })()}
            {slot.moderator && (() => {
              const m = splitSpeaker(slot.moderator);
              return <div class="text-xs text-muted">Moderator: {m.person}{m.affiliation ? ' ' + m.affiliation : ''}</div>;
            })()}
          </div>
        )
      ))}
    </section>
  ))}
</div>

<style>
  /* 會場 chip：色點＋同色邊框＋淡色底，與時間軸 session 顏色連動 */
  .venue-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    white-space: nowrap;
    border: 1px solid rgb(var(--chip));
    color: rgb(var(--chip));
    background: rgb(var(--chip) / 0.1);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .venue-chip::before {
    content: '';
    width: 0.55em;
    height: 0.55em;
    border-radius: 9999px;
    background: rgb(var(--chip));
    flex: none;
  }
  .chip-all::before { display: none; } /* 「全部」不對應單一顏色，不顯示色點 */
  /* 選中：填滿該 session 色，文字用頁面底色反轉以確保深淺色模式對比 */
  .venue-chip[data-active='true'] {
    background: rgb(var(--chip));
    color: rgb(var(--color-bg));
  }
  .venue-chip[data-active='true']::before { background: rgb(var(--color-bg)); }
</style>

<script>
  const root = document.querySelector('.agenda-mobile');
  if (root) {
    const chips = root.querySelectorAll<HTMLButtonElement>('.venue-chip');
    chips.forEach((chip) => chip.addEventListener('click', () => {
      const v = chip.dataset.venue!;
      chips.forEach((c) => { c.dataset.active = String(c === chip); });
      root.querySelectorAll<HTMLElement>('.track-card').forEach((card) => {
        card.style.display = v === 'all' || card.dataset.venue === v ? '' : 'none';
      });
      root.querySelectorAll<HTMLElement>('.slot-parallel').forEach((sec) => {
        const visible = Array.from(sec.querySelectorAll<HTMLElement>('.track-card')).some((c) => c.style.display !== 'none');
        sec.style.display = visible ? '' : 'none';
      });
    }));
  }
</script>
