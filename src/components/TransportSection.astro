---
import { t, type Lang } from '../lib/i18n';
const { lang } = Astro.props as { lang: Lang };
const mapSrc = 'https://www.google.com/maps?q=國立成功大學醫學院 成杏校區&output=embed';
const info = lang === 'zh'
  ? ['火車：台南火車站步行約 10 分鐘', '高鐵：台南站轉沙崙線至台南火車站']
  : ['Train: 10-min walk from Tainan Railway Station', 'HSR: Tainan HSR Station via Shalun line to Tainan Station'];
---
<section id="transport" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="mb-6 text-2xl font-bold text-accent">{t(lang, 'section.transport')}</h2>
  <div class="grid gap-6 md:grid-cols-2">
    <iframe src={mapSrc} class="h-72 w-full rounded-lg border border-line" loading="lazy"></iframe>
    <ul class="space-y-2 text-ink/80">{info.map((i) => <li>・{i}</li>)}</ul>
  </div>
</section>
